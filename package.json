{
  "name": "@teamgrid/developer-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.14 <25"
  },
  "scripts": {
    "build": "astro build",
    "check": "npm run generate && astro check && node scripts/validate-docs.mjs",
    "dev": "astro dev",
    "generate": "node scripts/generate-redirects.mjs && node scripts/generate-llms.mjs",
    "preview": "astro preview",
    "sync:contracts": "node scripts/sync-contracts.mjs",
    "sync:packages": "node scripts/sync-packages.mjs",
    "test:site": "node scripts/check-built-site.mjs",
    "verify": "npm run check && npm run build && npm run test:site"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "0.41.3",
    "astro": "7.1.1",
    "starlight-openapi": "0.26.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "form-data": "4.0.6"
  }
}
